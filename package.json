    "@types/react-dom": "^19.2.2",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.83.0"
